# Example Environment Configuration
# Copy this file to .env and adjust values for your environment

# =============================================================================
# SERVICE IDENTIFICATION
# =============================================================================

# Service name and version (required for OpenTelemetry)
OTEL_SERVICE_NAME=nestjs-observability-example
OTEL_SERVICE_VERSION=1.0.0

# Application environment
NODE_ENV=development

# =============================================================================
# OPENTELEMETRY EXPORTERS
# =============================================================================

# Traces exporter configuration
# Options: console, otlp, jaeger, zipkin, none
OTEL_TRACES_EXPORTER=console

# Metrics exporter configuration  
# Options: console, otlp, prometheus, none
OTEL_METRICS_EXPORTER=console

# Logs exporter configuration
# Options: console, otlp, none  
OTEL_LOGS_EXPORTER=console

# =============================================================================
# OTLP CONFIGURATION (for production)
# =============================================================================

# General OTLP endpoint (used by all signals if specific endpoints not set)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io

# Signal-specific OTLP endpoints (override general endpoint)
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://api.honeycomb.io/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=https://api.honeycomb.io/v1/metrics
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=https://api.honeycomb.io/v1/logs

# General OTLP headers (used by all signals if specific headers not set)
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-api-key

# Signal-specific OTLP headers (override general headers)
# OTEL_EXPORTER_OTLP_TRACES_HEADERS=x-honeycomb-team=your-traces-key
# OTEL_EXPORTER_OTLP_METRICS_HEADERS=x-honeycomb-team=your-metrics-key
# OTEL_EXPORTER_OTLP_LOGS_HEADERS=x-honeycomb-team=your-logs-key

# =============================================================================
# SAMPLING CONFIGURATION
# =============================================================================

# Trace sampling strategy
# Options: always_on, always_off, traceidratio, parentbased_always_on, parentbased_always_off, parentbased_traceidratio
OTEL_TRACES_SAMPLER=always_on

# Sampling ratio for traceidratio sampler (0.0 to 1.0)
# OTEL_TRACES_SAMPLER_ARG=0.1

# =============================================================================
# RESOURCE ATTRIBUTES
# =============================================================================

# Additional resource attributes (comma-separated key=value pairs)
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=backend,deployment.environment=development,custom.key=custom-value

# =============================================================================
# LIBRARY-SPECIFIC CONFIGURATION
# =============================================================================

# Enable/disable metrics endpoint
OTEL_METRICS_ENABLED=true

# Custom metrics endpoint path
OTEL_METRICS_ENDPOINT=/metrics

# Enable/disable span attribute sanitization for sensitive data
OTEL_SPAN_ATTRIBUTE_SANITIZATION_ENABLED=true

# Custom placeholder for redacted values
OTEL_SPAN_ATTRIBUTE_REDACTED_PLACEHOLDER=[REDACTED]

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# Batch span processor configuration
# OTEL_BSP_MAX_QUEUE_SIZE=2048
# OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512
# OTEL_BSP_EXPORT_TIMEOUT=30000
# OTEL_BSP_SCHEDULE_DELAY=5000

# Metrics export configuration
# OTEL_METRICS_EXPORT_INTERVAL=60000
# OTEL_METRICS_EXPORT_TIMEOUT=30000

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application port
PORT=3000

# Application host
HOST=localhost

# =============================================================================
# PLATFORM-SPECIFIC EXAMPLES
# =============================================================================

# Datadog
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.datadoghq.com
# OTEL_EXPORTER_OTLP_HEADERS=DD-API-KEY=your-datadog-api-key

# New Relic
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.nr-data.net:4317
# OTEL_EXPORTER_OTLP_HEADERS=api-key=your-newrelic-license-key

# Honeycomb
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-api-key

# Jaeger (self-hosted)
# OTEL_TRACES_EXPORTER=jaeger
# OTEL_EXPORTER_JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# Prometheus (self-hosted)
# OTEL_METRICS_EXPORTER=prometheus
# OTEL_EXPORTER_PROMETHEUS_HOST=0.0.0.0
# OTEL_EXPORTER_PROMETHEUS_PORT=9464