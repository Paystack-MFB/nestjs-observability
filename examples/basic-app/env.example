# Service Configuration
SERVICE_NAME=basic-example
SERVICE_VERSION=1.0.0
NODE_ENV=development
PORT=3000

# Logging Configuration
LOG_LEVEL=info
STRUCTURED_LOGGING=false

# Metrics Configuration
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics

# Tracing Configuration
TRACING_ENABLED=true
OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTLP_HEADERS={}

# Examples for external services:
# OTLP_TRACES_ENDPOINT=https://api.honeycomb.io/v1/traces
# OTLP_HEADERS={"x-honeycomb-team":"your-api-key"}

# OTLP_TRACES_ENDPOINT=https://otlp.nr-data.net:4318/v1/traces
# OTLP_HEADERS={"api-key":"your-new-relic-key"}
