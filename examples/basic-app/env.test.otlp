# Test Environment Configuration with OTLP
# Copy this to .env.test.otlp for testing with OTLP exporter
# =============================================================================
# SERVICE IDENTIFICATION
# =============================================================================

OTEL_SERVICE_NAME=nestjs-observability-example-test
OTEL_SERVICE_VERSION=1.0.0-test
OTEL_SERVICE_ENV=test
NODE_ENV=test

# =============================================================================
# OPENTELEMETRY EXPORTERS (Test with OTLP)
# =============================================================================

# Use OTLP for integration testing
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# =============================================================================
# OTLP CONFIGURATION (Test)
# =============================================================================

# Local OTLP endpoint for testing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs

# Test headers
OTEL_EXPORTER_OTLP_HEADERS=x-test-header=test-value
OTEL_EXPORTER_OTLP_TRACES_HEADERS=x-test-traces=true
OTEL_EXPORTER_OTLP_METRICS_HEADERS=x-test-metrics=true
OTEL_EXPORTER_OTLP_LOGS_HEADERS=x-test-logs=true

# =============================================================================
# SAMPLING CONFIGURATION (Test)
# =============================================================================

# Sample everything for testing
OTEL_TRACES_SAMPLER=always_on

# =============================================================================
# RESOURCE ATTRIBUTES (Test)
# =============================================================================

OTEL_RESOURCE_ATTRIBUTES=environment=test,test.type=integration,service.namespace=testing

# =============================================================================
# PERFORMANCE TUNING (Test)
# =============================================================================

# Fast export for testing
OTEL_BSP_MAX_QUEUE_SIZE=256
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=64
OTEL_BSP_EXPORT_TIMEOUT=5000
OTEL_BSP_SCHEDULE_DELAY=1000

# Fast metrics export for testing
OTEL_METRICS_EXPORT_INTERVAL=5000
OTEL_METRICS_EXPORT_TIMEOUT=5000

# =============================================================================
# SECURITY (Test)
# =============================================================================

# Enable sanitization for testing
OTEL_SPAN_ATTRIBUTE_SANITIZATION_ENABLED=true
OTEL_SPAN_ATTRIBUTE_REDACTED_PLACEHOLDER=[TEST_REDACTED]

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

PORT=3001
HOST=localhost
OTEL_METRICS_ENABLED=true
OTEL_METRICS_ENDPOINT=/metrics
