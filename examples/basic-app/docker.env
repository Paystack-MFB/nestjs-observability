# Docker Environment Configuration
# This file demonstrates OpenTelemetry configuration for Docker containers

# Service identification
OTEL_SERVICE_NAME=nestjs-observability-example
OTEL_SERVICE_VERSION=latest
NODE_ENV=production

# Use OTLP exporters with Docker network endpoints
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Docker-specific OTLP configuration using service names
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://jaeger:4317/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://prometheus:4317/v1/metrics
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://loki:4317/v1/logs

# Docker-specific headers (often for authentication)
# OTEL_EXPORTER_OTLP_HEADERS=x-docker-auth=container-token

# Conservative sampling for containers
OTEL_TRACES_SAMPLER=traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# Container resource attributes
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=docker,container.runtime=docker,service.namespace=containerized

# Additional attributes can be set dynamically via Docker
# docker run -e OTEL_RESOURCE_ATTRIBUTES="$OTEL_RESOURCE_ATTRIBUTES,container.id=$(hostname),container.image=my-app:latest"

# Library-specific features
OTEL_METRICS_ENABLED=true
OTEL_METRICS_ENDPOINT=/metrics
OTEL_SPAN_ATTRIBUTE_SANITIZATION_ENABLED=true

# Performance settings optimized for containers
OTEL_BSP_SCHEDULE_DELAY=5000           # Regular exports
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=256    # Conservative batch size
OTEL_BSP_MAX_QUEUE_SIZE=1024          # Limited memory usage
OTEL_BSP_EXPORT_TIMEOUT=15000         # Shorter timeout for containers
OTEL_METRICS_EXPORT_INTERVAL=30000    # Regular metrics export

# Container application settings
PORT=3000
HOST=0.0.0.0

# Container-friendly logging
# OTEL_LOG_LEVEL=info

# Example Docker Compose usage:
# services:
#   app:
#     image: my-nestjs-app:latest
#     env_file:
#       - docker.env
#     environment:
#       - OTEL_RESOURCE_ATTRIBUTES=${OTEL_RESOURCE_ATTRIBUTES},container.id=${HOSTNAME}
#     depends_on:
#       - otel-collector
#   
#   otel-collector:
#     image: otel/opentelemetry-collector-contrib:latest
#     ports:
#       - "4317:4317"
