# Test Environment Configuration for OTLP Integration Testing
# Used with mock OTLP collector for integration tests

# Application Configuration
OTEL_SERVICE_NAME=basic-example-test
OTEL_SERVICE_VERSION=1.0.0-test
NODE_ENV=test
PORT=3000

# Resource attributes for testing
OTEL_RESOURCE_ATTRIBUTES=service.name=basic-example-test,service.version=1.0.0-test,deployment.environment=test,test.run=integration

# OTLP exporters targeting mock collector
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Mock collector endpoints
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs

# Test headers for validation
OTEL_EXPORTER_OTLP_HEADERS=x-test-header=integration-test,x-source=nestjs-observability
OTEL_EXPORTER_OTLP_TRACES_HEADERS=x-trace-test=true
OTEL_EXPORTER_OTLP_METRICS_HEADERS=x-metrics-test=true
OTEL_EXPORTER_OTLP_LOGS_HEADERS=x-logs-test=true

# Fast export intervals for testing
OTEL_METRIC_EXPORT_INTERVAL=2000

# Sample all requests in tests
OTEL_TRACES_SAMPLER=always_on