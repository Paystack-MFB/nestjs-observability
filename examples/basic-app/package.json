{
  "name": "@paystackhq/nestjs-observability-basic-example",
  "version": "1.0.0",
  "description": "Basic example of using @paystackhq/nestjs-observability library",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "node -r ../../dist/cjs/register.js dist/src/main.js",
    "start:dev": "tsx -r ../../dist/cjs/register.js --watch src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node -r ../../dist/cjs/register.js dist/src/main.js",
    "start:development": "OTEL_TRACES_EXPORTER=console OTEL_METRICS_EXPORTER=console OTEL_LOGS_EXPORTER=console node -r ../../dist/cjs/register.js dist/src/main.js",
    "start:staging": "OTEL_TRACES_EXPORTER=otlp OTEL_METRICS_EXPORTER=otlp OTEL_LOGS_EXPORTER=otlp node -r ../../dist/cjs/register.js dist/src/main.js",
    "start:docker": "node -r ../../dist/cjs/register.js dist/src/main.js",
    "test:observability": "node scripts/test-observability-features.js",
    "demo:console": "OTEL_SERVICE_NAME=demo-console OTEL_TRACES_EXPORTER=console OTEL_METRICS_EXPORTER=console OTEL_LOGS_EXPORTER=console node -r ../../dist/cjs/register.js dist/src/main.js",
    "demo:metrics": "OTEL_METRICS_ENABLED=true OTEL_METRICS_ENDPOINT=/metrics node -r ../../dist/cjs/register.js dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --no-coverage",
    "test:e2e": "vitest run --config ./test/vitest-e2e.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "@paystackhq/nestjs-observability": "link:../..",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@swc/core": "^1.12.11",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "4.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.1.3",
    "unplugin-swc": "^1.5.5",
    "vitest": "^2.1.8"
  }
}
