{
  "name": "@paystackhq/nestjs-observability",
  "version": "1.4.3",
  "description": "A modern, production-ready observability package for NestJS applications with zero-configuration setup using OpenTelemetry 2025 best practices and the register pattern.",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "typesVersions": {
    "*": {
      "register": [
        "./dist/cjs/register.d.ts"
      ],
      "sdk": [
        "./dist/cjs/sdk.d.ts"
      ],
      "sdk-core": [
        "./dist/cjs/sdk-core.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm && pnpm run copy-package-json && pnpm run validate-build",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json && pnpm run fix-esm-imports",
    "build:info": "node scripts/build-info.js",
    "copy-package-json": "node scripts/copy-package-json.js",
    "fix-esm-imports": "node scripts/fix-esm-imports.js",
    "validate-build": "node scripts/validate-build.js",
    "dev": "tsx --watch src/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test",
    "release": "pnpm run clean && pnpm run build && changeset publish",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "husky",
    "rules:sync": "ai-coding-rules sync",
    "rules:check": "ai-coding-rules check"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.54.0",
    "@opentelemetry/auto-instrumentations-node": "^0.62.1",
    "@opentelemetry/core": "^2.2.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.54.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/instrumentation": "^0.208.0",
    "@opentelemetry/instrumentation-express": "^0.42.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.40.0",
    "@opentelemetry/instrumentation-router": "^0.39.0",
    "@opentelemetry/instrumentation-winston": "^0.34.0",
    "@opentelemetry/resources": "^2.0.1",
    "@opentelemetry/sdk-logs": "^0.54.0",
    "@opentelemetry/sdk-metrics": "^2.0.1",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/sdk-trace-base": "^2.0.1",
    "@opentelemetry/sdk-trace-node": "^2.0.1",
    "@opentelemetry/semantic-conventions": "^1.36.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.0",
    "@eslint/js": "^9.17.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.2",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tslib": "^2.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.2.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "default": "./dist/cjs/index.js"
    },
    "./register": {
      "types": "./dist/cjs/register.d.ts",
      "import": {
        "types": "./dist/esm/register.d.ts",
        "default": "./dist/esm/register.js"
      },
      "require": {
        "types": "./dist/cjs/register.d.ts",
        "default": "./dist/cjs/register.js"
      },
      "default": "./dist/cjs/register.js"
    },
    "./sdk": {
      "types": "./dist/cjs/sdk.d.ts",
      "import": {
        "types": "./dist/esm/sdk.d.ts",
        "default": "./dist/esm/sdk.js"
      },
      "require": {
        "types": "./dist/cjs/sdk.d.ts",
        "default": "./dist/cjs/sdk.js"
      },
      "default": "./dist/cjs/sdk.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "nestjs",
    "observability",
    "opentelemetry",
    "otel",
    "register-pattern",
    "zero-configuration",
    "environment-variables",
    "distributed-tracing",
    "structured-logging",
    "metrics-collection",
    "prometheus",
    "otlp",
    "monitoring",
    "telemetry",
    "apm",
    "instrumentation",
    "typescript",
    "production-ready"
  ],
  "author": "Paystack, Inc.",
  "license": "PROPRIETARY",
  "repository": {
    "type": "git",
    "url": "https://github.com/paystackhq/nestjs-observability.git"
  },
  "bugs": {
    "url": "https://github.com/paystackhq/nestjs-observability/issues"
  },
  "homepage": "https://github.com/paystackhq/nestjs-observability#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/swagger": ">7.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    }
  }
}
