{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Node",
    "outDir": "./dist/esm",
    "tsBuildInfoFile": "./dist/esm/.tsbuildinfo",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false
  }
}
